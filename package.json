{
  "name": "deflock-nc",
  "version": "0.0.0",
  "private": true,
  "description": "Static site for DeFlock Nevada County. Dev tooling only — no build step.",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "lint:html": "html-validate \"**/*.html\"",
    "lint:css": "stylelint \"assets/css/**/*.css\"",
    "lint": "npm run lint:html && npm run lint:css && npm run format:check"
  },
  "devDependencies": {
    "html-validate": "^9.0.0",
    "prettier": "^3.3.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
